styles:
  style_1:
    tw: block fixed z-0 font-normal leading-snug border-0 visible m-0 p-0 overflow-hidden
    custom:
      minWidth: 0px
      minHeight: 0px
      top: 0px
      right: 0px
      bottom: 0px
      left: 0px
      color: "rgba(0, 0, 0, 0.88)"
      fontSize: 14px
      fontFamily: "Roboto, sans-serif"
      textAlign: start
      textOverflow: clip
      border: "0px none rgba(0, 0, 0, 0.88)"
      borderColor: "rgba(0, 0, 0, 0.88)"
      background: "rgb(245, 245, 245) none repeat scroll 0% 0% / auto padding-box border-box"
      backgroundColor: "rgb(245, 245, 245)"
  style_2:
    tw: block static shrink-0 basis-56 max-w-xs font-normal leading-snug border-0 visible m-0 p-0 overflow-hidden
    custom:
      minWidth: 220px
      color: "rgba(0, 0, 0, 0.88)"
      fontSize: 14px
      fontFamily: "Roboto, sans-serif"
      textAlign: start
      textOverflow: clip
      border: "0px none rgba(0, 0, 0, 0.88)"
      borderColor: "rgba(0, 0, 0, 0.88)"
      transition: 0.2s
  style_3:
    tw: flex static items-center font-normal leading-10 whitespace-nowrap border-0 visible cursor-pointer m-0 p-0 overflow-visible
    custom:
      color: "rgb(0, 150, 136)"
      fontSize: 14px
      fontFamily: "Roboto, sans-serif"
      textAlign: start
      textOverflow: clip
      border: "0px none rgb(0, 150, 136)"
      borderColor: "rgb(0, 150, 136)"
  style_4:
    tw: block static max-w-full font-normal leading-10 whitespace-nowrap break-all border-0 visible cursor-pointer m-0 p-0 overflow-hidden
    custom:
      color: "rgb(0, 150, 136)"
      fontSize: 14px
      fontFamily: "Roboto, sans-serif"
      textAlign: start
      textOverflow: ellipsis
      border: "0px none rgb(0, 150, 136)"
      borderColor: "rgb(0, 150, 136)"
  style_5:
