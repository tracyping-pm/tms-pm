      textOverflow: ellipsis
      border: "0px none rgb(38, 38, 38)"
      borderColor: "rgb(38, 38, 38)"
      transition: color 0.3s
  style_13:
    tw: block absolute shrink-0 font-normal italic leading-10 whitespace-nowrap border-0 visible cursor-pointer m-0 p-0 overflow-visible
    custom:
      minWidth: 0px
      minHeight: 0px
      top: 20px
      right: 16px
      bottom: 20px
      left: 170.36px
      insetInlineStart: 170.36px
      insetInlineEnd: 16px
      insetBlockStart: 20px
      insetBlockEnd: 20px
      color: "rgb(38, 38, 38)"
      fontSize: 14px
      fontFamily: "Roboto, sans-serif"
      textAlign: start
      textOverflow: clip
      border: "0px none rgb(38, 38, 38)"
      borderColor: "rgb(38, 38, 38)"
      transform: "matrix(1, 0, 0, 1, 0, 0)"
      transition: "transform 0.3s cubic-bezier(0.645, 0.045, 0.355, 1), opacity 0.3s"
  style_14:
    tw: flex relative items-center font-normal leading-10 whitespace-nowrap border-0 visible cursor-pointer m-1 pt-0 pr-8 pb-0 pl-4 overflow-hidden
    custom:
      minWidth: 0px
      minHeight: 0px
      padding: 0px 34px 0px 16px
      marginInlineStart: 4px
      marginInlineEnd: 4px
      marginBlockStart: 4px
      marginBlockEnd: 4px
      paddingInlineStart: 16px
      paddingInlineEnd: 34px
      top: 0px
      right: 0px
      bottom: 0px
      left: 0px
      color: "rgb(38, 38, 38)"
      fontSize: 14px
      fontFamily: "Roboto, sans-serif"
      textAlign: start
      textOverflow: ellipsis
      border: "0px none rgb(38, 38, 38)"
      borderColor: "rgb(38, 38, 38)"
      borderRadius: 6px
      transition: "border-color 0.3s, background 0.3s, padding 0.1s cubic-bezier(0.215, 0.61, 0.355, 1)"
  style_15:
    tw: static font-normal leading-3 border-0 visible m-0 p-0 overflow-visible
    custom:
      display: list-item
      minWidth: 0px
      minHeight: 0px
      color: "rgb(38, 38, 38)"
      fontSize: 14px
      fontFamily: "Roboto, sans-serif"
      textAlign: start
      textOverflow: clip
